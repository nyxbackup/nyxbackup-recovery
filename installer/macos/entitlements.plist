<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened Runtime entitlements for the Nyx Backup .app bundles
  (main app + Recovery Tool).  Applied via codesign --entitlements
  during the signing step in scripts/macos/build_pkg_arm64.sh and
  scripts/macos/build_recover_pkg_arm64.sh.

  These three entries are the documented minimum for any Tauri 2
  app on macOS:

  - com.apple.security.cs.allow-jit
      JavaScriptCore JIT-compiles hot code paths in WKWebView; without
      this entitlement the Hardened Runtime kills the process on the
      first JIT page allocation with "EXC_BAD_ACCESS (code=2)".

  - com.apple.security.cs.allow-unsigned-executable-memory
      WKWebView allocates executable pages for its render pipeline
      that are not themselves signed; without this entitlement
      `mmap` with PROT_EXEC fails inside WebKit and the renderer
      hangs.

  - com.apple.security.cs.disable-library-validation
      Tauri dynamically loads frameworks (libwebkit2gtk-3.0.dylib on
      WKWebView's path, plus tauri-plugin-shell + dialog).  Without
      this entitlement the loader refuses any dylib whose Team ID
      differs from the main executable's - which on a vendor app
      that links WebKit means "everything".

  The CLI, TUI, daemon, and toast binaries do NOT include these
  entitlements.  They have no JIT and no embedded browser; granting
  them anyway would needlessly widen the attack surface of the
  service that runs as root.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
